# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Microsoft Azure AD ─────────────────────────────────────────────────────────
# From your Azure AD App Registration
MICROSOFT_CLIENT_ID=your_azure_app_client_id
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret
MICROSOFT_TENANT_ID=your_azure_tenant_id

# Must match the redirect URI registered in Azure AD.
# In dev (with Vite proxy): http://localhost:5173/auth/callback
# In production:            https://yourapp.com/auth/callback
REDIRECT_URI=http://localhost:5173/auth/callback

# ── App Config ─────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_secret
